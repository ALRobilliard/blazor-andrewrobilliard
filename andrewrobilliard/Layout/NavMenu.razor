<div class="fixed-top bg-light">
    <nav class="navbar navbar-expand-md navbar-light px-4">
        <a class="navbar-brand" href="/">Andrew Robilliard</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent"
                aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"
                @onclick="ToggleNavBar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse @(isNavBarCollapsed ? "show" : "")" id="navbarSupportedContent">
            <ul class="navbar-nav ms-auto">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="about-me">
                        <i class="bi bi-person-circle" aria-hidden="true" style="font-size: 1.25rem;"></i> About Me
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="contact">
                        <span class="bi bi-person-lines-fill" aria-hidden="true" style="font-size: 1.25rem;"></span>
                        Contact
                    </NavLink>
                </div>
            </ul>
        </div>
    </nav>
</div>

@code {
    private bool isNavBarCollapsed = true;
    private void ToggleNavBar()
    {
        isNavBarCollapsed = !isNavBarCollapsed;
    }
}